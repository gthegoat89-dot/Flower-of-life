<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Flower of Life — Symmetry & Deviation</title>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #0e0e10;
    --surface: #17171a;
    --border: rgba(255,255,255,0.08);
    --text-primary: #e8e6de;
    --text-secondary: #8a8880;
    --accent: #9b8aff;
    --accent-dim: rgba(155,138,255,0.15);
    --gold: #f0c060;
    --red: #ff6b4a;
    --green: #4adbb0;
    --font: 'Segoe UI', system-ui, -apple-system, sans-serif;
    --mono: 'Courier New', monospace;
  }

  body {
    background: var(--bg);
    color: var(--text-primary);
    font-family: var(--font);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  header {
    width: 100%;
    max-width: 780px;
    padding: 48px 24px 0;
    text-align: center;
  }

  .eyebrow {
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 16px;
  }

  h1 {
    font-size: clamp(26px, 5vw, 42px);
    font-weight: 300;
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: var(--text-primary);
    margin-bottom: 16px;
  }

  h1 em {
    font-style: normal;
    color: var(--gold);
    font-weight: 500;
  }

  .subtitle {
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.65;
    max-width: 560px;
    margin: 0 auto 40px;
  }

  .card {
    width: 100%;
    max-width: 780px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
    margin: 0 24px;
  }

  canvas {
    display: block;
    width: 100%;
    cursor: crosshair;
  }

  .controls {
    padding: 20px 24px;
    border-top: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .ctrl-row {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .ctrl-label {
    font-size: 12px;
    color: var(--text-secondary);
    min-width: 140px;
    letter-spacing: 0.02em;
  }

  input[type=range] {
    flex: 1;
    -webkit-appearance: none;
    appearance: none;
    height: 3px;
    background: var(--border);
    border-radius: 2px;
    outline: none;
    cursor: pointer;
  }

  input[type=range]::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--accent);
    cursor: pointer;
    transition: transform 0.15s;
  }

  input[type=range]::-webkit-slider-thumb:hover { transform: scale(1.2); }

  .ctrl-value {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--accent);
    min-width: 36px;
    text-align: right;
  }

  .toggle-row {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
  }

  .toggle-label {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    color: var(--text-secondary);
    cursor: pointer;
    user-select: none;
  }

  .toggle-label input { display: none; }

  .toggle-pill {
    width: 34px;
    height: 18px;
    background: var(--border);
    border-radius: 9px;
    position: relative;
    transition: background 0.2s;
  }

  .toggle-pill::after {
    content: '';
    position: absolute;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--text-secondary);
    top: 3px;
    left: 3px;
    transition: transform 0.2s, background 0.2s;
  }

  .toggle-label input:checked + .toggle-pill { background: var(--accent-dim); border: 1px solid var(--accent); }
  .toggle-label input:checked + .toggle-pill::after { transform: translateX(16px); background: var(--accent); }

  .info-bar {
    padding: 14px 24px;
    border-top: 1px solid var(--border);
    font-size: 12px;
    color: var(--text-secondary);
    line-height: 1.6;
    font-family: var(--mono);
    min-height: 52px;
  }

  .info-bar span { color: var(--red); font-weight: 600; }
  .info-bar .ok { color: var(--green); }

  .explainer {
    width: 100%;
    max-width: 780px;
    padding: 40px 24px 24px;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 16px;
  }

  .exp-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 20px;
  }

  .exp-num {
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 8px;
  }

  .exp-title {
    font-size: 14px;
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: 8px;
    line-height: 1.3;
  }

  .exp-body {
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .context-note {
    width: 100%;
    max-width: 780px;
    padding: 0 24px 48px;
  }

  .context-note p {
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.7;
    border-left: 2px solid var(--accent-dim);
    padding-left: 16px;
  }

  .context-note a {
    color: var(--accent);
    text-decoration: none;
  }

  footer {
    width: 100%;
    max-width: 780px;
    padding: 0 24px 40px;
    text-align: center;
    font-size: 12px;
    color: var(--text-secondary);
    border-top: 1px solid var(--border);
    margin: 0 24px;
    padding-top: 20px;
  }

  @media (max-width: 500px) {
    .ctrl-label { min-width: 100px; }
    .explainer { grid-template-columns: 1fr; }
  }

  @media (prefers-reduced-motion: reduce) {
    * { transition: none !important; animation: none !important; }
  }
</style>
</head>
<body>

<header>
  <p class="eyebrow">Sacred Geometry &amp; Ancient Precision</p>
  <h1>The <em>Flower of Life</em><br>and the tyranny of compounding error</h1>
  <p class="subtitle">One misplaced circle. Six rings of chaos. This interactive shows why achieving micrometer-level precision across a Flower of Life geometry let alone translating it into three dimensions on granite — implies manufacturing capabilities that have never been satisfactorily explained.</p>
</header>

<div class="card">
  <canvas id="c"></canvas>
  <div class="controls">
    <div class="ctrl-row">
      <span class="ctrl-label">Positional error (px)</span>
      <input type="range" id="err" min="0" max="20" step="0.1" value="0">
      <span class="ctrl-value" id="errV">0.0</span>
    </div>
    <div class="ctrl-row">
      <span class="ctrl-label">Rings</span>
      <input type="range" id="rings" min="1" max="3" step="1" value="2">
      <span class="ctrl-value" id="ringsV">2</span>
    </div>
    <div class="toggle-row">
      <label class="toggle-label">
        <input type="checkbox" id="show3d">
        <span class="toggle-pill"></span>
        3D sphere projection
      </label>
      <label class="toggle-label">
        <input type="checkbox" id="showErr" checked>
        <span class="toggle-pill"></span>
        Highlight deviations
      </label>
    </div>
  </div>
  <div class="info-bar" id="infoBar">
    <span class="ok">Perfect symmetry.</span> Every circle centre resolves exactly to the intersection of its neighbours. Every petal closes precisely. Drag the error slider to introduce a positional mistake.
  </div>
</div>

<div class="explainer">
  <div class="exp-card">
    <p class="exp-num">Construction</p>
    <p class="exp-title">How it's drawn</p>
    <p class="exp-body">Start with one circle — the seed. Place six identical circles with their centres on the seed's circumference, 60° apart. Each of those six generates six more. The radius must be identical every time, and every centre must sit <em>exactly</em> on a neighbour's circumference not approximately.</p>
  </div>
  <div class="exp-card">
    <p class="exp-num">Compounding</p>
    <p class="exp-title">Why error cascades</p>
    <p class="exp-body">Each Ring 2 circle is positioned relative to two Ring 1 circles so it inherits both their errors simultaneously. Ring 3 inherits from Ring 2. A 2px error in Ring 1 becomes a 7px error by Ring 3. The structure is self-verifying: if you're right, everything closes; if you're wrong, nothing does.</p>
  </div>
  <div class="exp-card">
    <p class="exp-num">3D Translation</p>
    <p class="exp-title">The curvature multiplier</p>
    <p class="exp-body">Mapping this geometry onto a curved surface — the interior of a stone vase adds a curvature multiplier on top of the compounding. A surface error that measures 2px in 2D becomes a depth error <em>and</em> a surface error in 3D. Correcting one axis shifts the other. The errors multiply, not add.</p>
  </div>
  <div class="exp-card">
    <p class="exp-num">The Vase Question</p>
    <p class="exp-title">What this implies</p>
    <p class="exp-body">Pre-dynastic Egyptian granite vessels have been found encoding π and φ² to within 20–32 micrometers across 12 interrelated radii. A human hair is ~70 micrometers thick. Analysts concluded a minimum of 5-axis constrained machining controlling this compounding error at every point simultaneously would be required to achieve it.</p>
  </div>
</div>

<div class="context-note">
 
</div>

<footer>
  Built with plain HTML &amp; Canvas. No frameworks. No tracking. — <a href="https://github.com" style="color:var(--accent)">View source on GitHub</a>
</footer>

<script>
const canvas = document.getElementById('c');
const ctx = canvas.getContext('2d');
const errSlider = document.getElementById('err');
const ringsSlider = document.getElementById('rings');
const show3dToggle = document.getElementById('show3d');
const showErrToggle = document.getElementById('showErr');
const errV = document.getElementById('errV');
const ringsV = document.getElementById('ringsV');
const infoBar = document.getElementById('infoBar');

function resize() {
  const w = Math.min(canvas.parentElement.clientWidth, 780);
  const dpr = window.devicePixelRatio || 1;
  canvas.width = w * dpr;
  const do3d = show3dToggle.checked;
  canvas.height = (do3d ? w * 1.1 : w * 0.85) * dpr;
  canvas.style.width = w + 'px';
  canvas.style.height = (do3d ? w * 1.1 : w * 0.85) + 'px';
  draw();
}

function draw() {
  const W = canvas.width, H = canvas.height;
  const dpr = window.devicePixelRatio || 1;
  ctx.clearRect(0, 0, W, H);

  const bg = '#0e0e10';
  ctx.fillStyle = bg;
  ctx.fillRect(0, 0, W, H);

  const err = parseFloat(errSlider.value) * dpr;
  const numRings = parseInt(ringsSlider.value);
  const showError = showErrToggle.checked;
  const do3d = show3dToggle.checked;

  const cx = W / 2;
  const cy = do3d ? H * 0.40 : H / 2;
  const r = W * 0.105;

  const dirs = Array.from({length:6}, (_,i) => [
    Math.cos(i * Math.PI / 3),
    Math.sin(i * Math.PI / 3)
  ]);

  const ring1 = dirs.map(d => [d[0]*r, d[1]*r]);

  let ring2 = [];
  if (numRings >= 2) {
    for (let i = 0; i < 6; i++) {
      const d1 = dirs[i], d2 = dirs[(i+1)%6];
      ring2.push([d1[0]*r*2, d1[1]*r*2]);
      ring2.push([(d1[0]+d2[0])*r, (d1[1]+d2[1])*r]);
    }
  }

  let ring3 = [];
  if (numRings >= 3) {
    for (let i = 0; i < 6; i++) {
      const d1 = dirs[i], d2 = dirs[(i+1)%6];
      ring3.push([d1[0]*r*3, d1[1]*r*3]);
      ring3.push([d1[0]*r*2+d2[0]*r, d1[1]*r*2+d2[1]*r]);
      ring3.push([d1[0]*r+d2[0]*r*2, d1[1]*r+d2[1]*r*2]);
    }
  }

  function applyErr(ring, mult) {
    return ring.map((p, i) => {
      const angle = Math.atan2(p[1], p[0]);
      const ex = Math.cos(angle * 1.7 + i * 0.31) * err * mult;
      const ey = Math.sin(angle * 2.3 + i * 0.47) * err * mult;
      return [p[0]+ex, p[1]+ey];
    });
  }

  const r1e = applyErr(ring1, 1);
  const r2e = numRings >= 2 ? applyErr(ring2, 2.1) : [];
  const r3e = numRings >= 3 ? applyErr(ring3, 3.7) : [];

  function drawCircles(perfect, actual) {
    perfect.forEach((p, i) => {
      const a = actual[i];
      if (err > 0.3) {
        ctx.beginPath();
        ctx.arc(cx+p[0], cy+p[1], r, 0, Math.PI*2);
        ctx.strokeStyle = 'rgba(74,219,176,0.25)';
        ctx.lineWidth = 0.6 * dpr;
        ctx.setLineDash([5*dpr, 4*dpr]);
        ctx.stroke();
        ctx.setLineDash([]);
      }
      ctx.beginPath();
      ctx.arc(cx+a[0], cy+a[1], r, 0, Math.PI*2);
      ctx.strokeStyle = err > 0.3 ? 'rgba(155,138,255,0.5)' : 'rgba(155,138,255,0.65)';
      ctx.lineWidth = 1.2 * dpr;
      ctx.stroke();

      if (showError && err > 0.3) {
        const dx = a[0]-p[0], dy = a[1]-p[1];
        if (Math.sqrt(dx*dx+dy*dy) > 1) {
          ctx.beginPath();
          ctx.moveTo(cx+p[0], cy+p[1]);
          ctx.lineTo(cx+a[0], cy+a[1]);
          ctx.strokeStyle = 'rgba(255,107,74,0.9)';
          ctx.lineWidth = 1.8 * dpr;
          ctx.stroke();
          ctx.beginPath();
          ctx.arc(cx+a[0], cy+a[1], 3.5*dpr, 0, Math.PI*2);
          ctx.fillStyle = '#ff6b4a';
          ctx.fill();
        }
      }
    });
  }

  // Seed
  ctx.beginPath();
  ctx.arc(cx, cy, r, 0, Math.PI*2);
  ctx.strokeStyle = '#f0c060';
  ctx.lineWidth = 2*dpr;
  ctx.stroke();
  ctx.beginPath();
  ctx.arc(cx, cy, 4*dpr, 0, Math.PI*2);
  ctx.fillStyle = '#f0c060';
  ctx.fill();

  drawCircles(ring1, r1e);
  if (numRings >= 2) drawCircles(ring2, r2e);
  if (numRings >= 3) drawCircles(ring3, r3e);

  // 3D sphere
  if (do3d) {
    const sR = W * 0.12;
    const sy = H * 0.80;

    // Sphere glow
    const grad = ctx.createRadialGradient(cx, sy, 0, cx, sy, sR);
    grad.addColorStop(0, 'rgba(155,138,255,0.18)');
    grad.addColorStop(0.7, 'rgba(155,138,255,0.08)');
    grad.addColorStop(1, 'rgba(155,138,255,0)');
    ctx.beginPath();
    ctx.arc(cx, sy, sR*1.3, 0, Math.PI*2);
    ctx.fillStyle = grad;
    ctx.fill();

    ctx.beginPath();
    ctx.arc(cx, sy, sR, 0, Math.PI*2);
    ctx.strokeStyle = 'rgba(155,138,255,0.45)';
    ctx.lineWidth = 1.5*dpr;
    ctx.stroke();

    // Latitude lines
    for (let lat = -60; lat <= 60; lat += 30) {
      const latR = Math.cos(lat*Math.PI/180) * sR;
      const latY = sy + Math.sin(lat*Math.PI/180) * sR * 0.35;
      ctx.beginPath();
      ctx.ellipse(cx, latY, latR, latR*0.2, 0, 0, Math.PI*2);
      ctx.strokeStyle = 'rgba(155,138,255,0.12)';
      ctx.lineWidth = 0.5*dpr;
      ctx.stroke();
    }

    // Project FOL points
    const allP = [[0,0], ...r1e, ...r2e, ...r3e];
    const maxR = r * (numRings + 0.8);
    allP.forEach(p => {
      const nx = p[0]/maxR, ny = p[1]/maxR;
      const d2 = nx*nx + ny*ny;
      if (d2 > 0.95) return;
      const nz = Math.sqrt(1-d2);
      const px2 = cx + nx*sR;
      const py2 = sy + ny*sR*0.38 - nz*sR*0.28;
      const dotR = (1.8 + nz*2.5)*dpr;
      ctx.beginPath();
      ctx.arc(px2, py2, dotR, 0, Math.PI*2);
      ctx.fillStyle = err > 0.3 ? 'rgba(255,107,74,0.85)' : 'rgba(155,138,255,0.8)';
      ctx.fill();
    });

    ctx.fillStyle = 'rgba(138,136,128,0.7)';
    ctx.font = `${11*dpr}px 'Segoe UI', sans-serif`;
    ctx.textAlign = 'center';
    ctx.fillText('3D projection — curvature multiplies existing error', cx, sy + sR + 18*dpr);
  }

  // Legend (top left)
  const lx = 18*dpr, ly = 20*dpr;
  ctx.textAlign = 'left';
  ctx.font = `${11*dpr}px 'Segoe UI', sans-serif`;

  ctx.strokeStyle = '#f0c060'; ctx.lineWidth = 2*dpr; ctx.setLineDash([]);
  ctx.beginPath(); ctx.moveTo(lx, ly); ctx.lineTo(lx+18*dpr, ly); ctx.stroke();
  ctx.fillStyle = '#8a8880'; ctx.fillText('Seed circle', lx+22*dpr, ly+4*dpr);

  ctx.strokeStyle = 'rgba(155,138,255,0.65)'; ctx.lineWidth = 1.2*dpr;
  ctx.beginPath(); ctx.moveTo(lx, ly+15*dpr); ctx.lineTo(lx+18*dpr, ly+15*dpr); ctx.stroke();
  ctx.fillStyle = '#8a8880'; ctx.fillText('Placed circle', lx+22*dpr, ly+19*dpr);

  if (err > 0.3) {
    ctx.strokeStyle = 'rgba(74,219,176,0.4)'; ctx.setLineDash([4*dpr,3*dpr]); ctx.lineWidth = 0.6*dpr;
    ctx.beginPath(); ctx.moveTo(lx, ly+30*dpr); ctx.lineTo(lx+18*dpr, ly+30*dpr); ctx.stroke();
    ctx.setLineDash([]);
    ctx.fillStyle = '#8a8880'; ctx.fillText('Perfect position', lx+22*dpr, ly+34*dpr);

    ctx.strokeStyle = 'rgba(255,107,74,0.9)'; ctx.lineWidth = 1.8*dpr;
    ctx.beginPath(); ctx.moveTo(lx, ly+45*dpr); ctx.lineTo(lx+18*dpr, ly+45*dpr); ctx.stroke();
    ctx.fillStyle = '#8a8880'; ctx.fillText('Deviation vector', lx+22*dpr, ly+49*dpr);
  }

  // Update info bar
  const e = parseFloat(errSlider.value);
  if (e < 0.2) {
    infoBar.innerHTML = '<span class="ok">Perfect symmetry.</span> Every circle centre resolves exactly to the intersection of its neighbours. Every petal closes precisely. Drag the error slider to introduce a positional mistake.';
  } else {
    const r2 = (e * 2.1).toFixed(1);
    const r3 = (e * 3.7).toFixed(1);
    const d3 = (e * 5.5).toFixed(1);
    infoBar.innerHTML = `Ring 1 error: <span>±${e.toFixed(1)}px</span> → Ring 2: <span>±${r2}px</span> (×2.1) → Ring 3: <span>±${r3}px</span> (×3.7). In 3D the curvature multiplier pushes this to <span>±${d3}px</span> at depth. Ancient vase tolerances: ±0.00003px (20 micrometres).`;
  }
}

errSlider.addEventListener('input', () => { errV.textContent = parseFloat(errSlider.value).toFixed(1); draw(); });
ringsSlider.addEventListener('input', () => { ringsV.textContent = ringsSlider.value; draw(); });
show3dToggle.addEventListener('change', resize);
showErrToggle.addEventListener('change', draw);
window.addEventListener('resize', resize);
resize();
</script>
</body>
</html>
